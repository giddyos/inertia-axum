import { createElement } from 'react';
import { createInertiaApp } from '@inertiajs/react';
import { createRoot } from 'react-dom/client';
createInertiaApp({ resolve: name => import(`./Pages/${name}.tsx`), setup: ({ el, App, props }) => createRoot(el).render(createElement(App, props)) });
